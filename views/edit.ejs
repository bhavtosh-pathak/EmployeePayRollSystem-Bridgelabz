<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Student</title>
</head>
<body>

    <h1>Edit Student Details</h1>

    <form action="/student/edit/<%= student.id %>" method="POST">
        
        <label>Name:</label><br>
        <input type="text" name="name" value="<%= student.name %>" required>
        <br><br>

        <label>Age:</label><br>
        <input type="number" name="age" value="<%= student.age %>" required>
        <br><br>

        <label>Branch:</label><br>
        <select name="branch">
            <option value="CSE" <%= student.branch === "CSE" ? "selected" : "" %>>CSE</option>
            <option value="IT" <%= student.branch === "IT" ? "selected" : "" %>>IT</option>
            <option value="ECE" <%= student.branch === "ECE" ? "selected" : "" %>>ECE</option>
        </select>
        <br><br>

        <button type="submit">Update</button>
    </form>

    <br>
    <a href="/students">Back to List</a>

</body>
</html>
